# Server
PORT=3000
NODE_ENV=development

# Postgres (used by Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/media_pipeline?schema=public"

# Redis (used by BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=15

# Analysis thresholds (tunable without redeploying analysis code)
BLUR_VARIANCE_THRESHOLD=100
BRIGHTNESS_LOW_THRESHOLD=60
BRIGHTNESS_HIGH_THRESHOLD=200
DUPLICATE_HAMMING_DISTANCE_THRESHOLD=5
MIN_IMAGE_WIDTH=400
MIN_IMAGE_HEIGHT=300
